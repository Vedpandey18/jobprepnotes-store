# --- Local: SQLite (set provider to sqlite in prisma/schema.prisma) ---
# DATABASE_URL="file:./prisma/dev.db"

# --- Production (Vercel + Neon): PostgreSQL ---
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

USE_DEMO_CATALOG=false

ADMIN_EMAIL=admin@jobprepnotes.com
ADMIN_PASSWORD=admin123
ADMIN_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Optional: external SuperProfile payment URL for checkout redirect flow
NEXT_PUBLIC_SUPERPROFILE_CHECKOUT_URL=
